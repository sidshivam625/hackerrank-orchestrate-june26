# ============================================================
# Multi-Modal Claims Verification System — Environment Config
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================

# --- Google Vertex AI / Gemini ---
# Your GCP project ID (e.g. my-gcp-project-12345)
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for Vertex AI (e.g. us-central1)
GCP_REGION=us-central1

# Path to your GCP service account key JSON file (optional if using ADC)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Primary VLM model name (Gemini 2.5 Flash recommended)
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Enable Vertex AI context caching (true/false)
ENABLE_CONTEXT_CACHE=true

# Context cache TTL in seconds (default 7200 = 2 hours)
CONTEXT_CACHE_TTL_SECONDS=7200

# --- AIML API (Open-Source Models) ---
# Your AIML API key for Qwen3-VL-32B escalation
AIML_API_KEY=your-aiml-api-key

# AIML API base URL
AIML_API_BASE_URL=https://api.aimlapi.com/v1

# Escalation model for uncertain/conflicting claims
ESCALATION_MODEL=alibaba/qwen3-vl-32b-instruct

# --- Pipeline Tuning ---
# Maximum concurrent API requests (keep below RPM limit)
MAX_CONCURRENT_REQUESTS=8

# Maximum retries on 429/5xx errors
MAX_RETRIES=4

# OpenCV blur detection threshold (Laplacian variance)
BLUR_THRESHOLD=12.0

# Brightness thresholds (min/max)
BRIGHTNESS_MIN=30.0
BRIGHTNESS_MAX=235.0

# Minimum image resolution (pixels)
MIN_IMAGE_WIDTH=64
MIN_IMAGE_HEIGHT=64

# Color entropy threshold for blank/obstructed image detection
ENTROPY_THRESHOLD=3.0

# Rejection ratio threshold for user history risk flag
USER_REJECTION_RATIO_THRESHOLD=0.35

# Last 90 days claim count threshold for velocity flag
USER_VELOCITY_THRESHOLD=3

# Enable Qwen escalation for uncertain claims (true/false)
ENABLE_ESCALATION=true

# --- Paths ---
# Dataset root (relative to repo root or absolute)
DATASET_DIR=../dataset

# Output file path
OUTPUT_CSV=../output.csv

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# --- Self-consistency (majority vote of K VLM samples) ---
# K=1 disables it (deterministic single pass). K=3 recommended if you have credits.
SELF_CONSISTENCY_SAMPLES=1
# Sampling temperature used ONLY when SELF_CONSISTENCY_SAMPLES>1 (needs diversity)
SELF_CONSISTENCY_TEMPERATURE=0.4
